# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/android/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local packaged APKs are uploaded as GitHub Release assets, not committed.
/dist/*.apk
/dist/*.aab
/dist/*.zip
/dist/*.jobpack

# Local-only exports, screenshots, and scratch files.
/exports/
/screenshots/
/captures/
/tmp/
/temp/

# Local AI-agent instructions and working memory are not project source.
/Agents.md
/AGENTS.md
/.ai/
/.agents/
/.codex/

# AI tooling indices/configs are local, not project source.
/.codegraph/
/.cursor/
/.claude/

# Internal design/handoff docs are kept local, not published.
/docs/
